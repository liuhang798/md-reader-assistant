{
  "name": "leafmd",
  "productName": "MD阅读助手",
  "version": "1.4.0",
  "description": "美观易用的 Windows Markdown 阅读与编辑工具",
  "main": "src/main.js",
  "author": "MD阅读助手",
  "license": "MIT",
  "scripts": {
    "dev": "npm run build:renderer && electron .",
    "build:renderer": "esbuild src/renderer.js --bundle --minify --sourcemap --outfile=dist/renderer.js",
    "build": "npm run build:renderer && electron-builder --win nsis --x64"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.1",
    "codemirror": "^6.0.2",
    "dompurify": "^3.2.6",
    "highlight.js": "^11.11.1",
    "marked": "^15.0.12"
  },
  "devDependencies": {
    "electron": "^37.2.3",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.6"
  },
  "build": {
    "appId": "com.mdreader.assistant",
    "productName": "MD阅读助手",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "dist/**/*",
      "build/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "MD阅读助手-安装程序-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "perMachine": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "MD阅读助手",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown",
          "mdown",
          "mkd"
        ],
        "name": "Markdown 文档",
        "description": "Markdown 文档",
        "icon": "build/icon.ico",
        "role": "Editor"
      }
    ]
  }
}
